{
  "name": "capira-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync-env-backup": "node -e \"try{const f=require('fs');if(f.existsSync('.env.local')){f.copyFileSync('.env.local','data/env.local.backup');console.log('[sync-env] data/env.local.backup actualizado')}}catch(e){console.warn('[sync-env]',e.message)}\"",
    "predev": "npm run sync-env-backup",
    "prebuild": "npm run sync-env-backup",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.103.0",
    "@types/leaflet": "^1.9.21",
    "@vercel/analytics": "^2.0.1",
    "echarts": "^6.0.0",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "next": "16.1.1",
    "pdf-lib": "^1.17.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "fast-xml-parser": "^5.7.1",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
